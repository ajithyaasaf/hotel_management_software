generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum UserRole {
  ADMIN
  RECEPTION
  RESTAURANT
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  BLOCKED
}

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum OrderType {
  ROOM
  WALK_IN
  TAKEAWAY
}

enum OrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BTC
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FULL
  REFUND
}

enum AdjustmentType {
  DISCOUNT_FLAT
  DISCOUNT_PERCENT
  EXTRA_CHARGE
}

enum ExpenseCategory {
  ELECTRICITY
  WATER
  STAFF_SALARY
  KITCHEN_SUPPLIES
  LAUNDRY
  MAINTENANCE
  HOUSEKEEPING
  MARKETING
  MISCELLANEOUS
}

enum GroupBookingStatus {
  ACTIVE
  PARTIALLY_CHECKED_OUT
  COMPLETED
  CANCELLED
}

enum NightAuditStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum BillingRule {
  GUEST
  COMPANY_ROOM_ONLY
  COMPANY_ALL
}

enum BanquetSlot {
  MORNING   // Breakfast slot (e.g. 7AM - 12PM)
  AFTERNOON // Lunch slot    (e.g. 12PM - 5PM)
  EVENING   // Dinner slot   (e.g. 6PM - 11PM)
  CUSTOM    // Hourly flex — uses startTime / endTime fields
}

enum BanquetStatus {
  PROVISIONAL // Slot held, awaiting deposit
  CONFIRMED   // Deposit paid, event locked
  COMPLETED   // Event ended, folio settled
  CANCELLED   // Event cancelled
}

enum BanquetPaymentType {
  ADVANCE    // Initial booking deposit
  SETTLEMENT // Remaining balance payment
  REFUND     // Cancellation refund
}

// ─── USERS ──────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(RECEPTION)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings        Booking[]
  orders          Order[]
  payments        Payment[]
  auditLogs       AuditLog[]
  adjustments     InvoiceAdjustment[]
  expenses        Expense[]
  groupBookings   GroupBooking[]
  nightAudits     NightAudit[]
  companyPayments CompanyPayment[]
  banquetPayments BanquetPayment[] @relation("BanquetPaymentCreator")
  banquetBookings BanquetBooking[] @relation("BanquetBookingCreator")

  @@map("users")
}

// ─── ROOM TYPES ─────────────────────────────────────────

model RoomType {
  id           String   @id @default(uuid())
  name         String   @unique
  basePrice    Decimal  @db.Decimal(10, 2)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rooms Room[]

  @@map("room_types")
}

// ─── ROOMS ──────────────────────────────────────────────

model Room {
  id           String     @id @default(uuid())
  roomNumber   String     @unique
  floor        Int        @default(1)
  roomTypeId   String
  roomType     RoomType   @relation(fields: [roomTypeId], references: [id])
  status       RoomStatus @default(AVAILABLE)
  blockReason  String?
  blockStart   DateTime?
  blockEnd     DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  bookings      Booking[]
  orders        Order[]
  transfersFrom RoomTransfer[] @relation("TransferFromRoom")
  transfersTo   RoomTransfer[] @relation("TransferToRoom")
  nightAuditCharges NightAuditCharge[]

  @@index([roomTypeId])
  @@map("rooms")
}

// ─── GUESTS ─────────────────────────────────────────────

model Guest {
  id            String   @id @default(uuid())
  name          String
  phone         String   @unique
  email         String?
  idProofType   String?
  idProofNumber String?
  idProofUrl    String?
  address       String?
  visitCount    Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings        Booking[]
  groupBookings   GroupBooking[]
  banquetBookings BanquetBooking[]

  @@index([phone])
  @@map("guests")
}

// ─── BOOKINGS ───────────────────────────────────────────

model Booking {
  id                String        @id @default(uuid())
  bookingNumber     String        @unique
  guestId           String
  guest             Guest         @relation(fields: [guestId], references: [id])
  roomId            String
  room              Room          @relation(fields: [roomId], references: [id])
  status            BookingStatus @default(CONFIRMED)
  checkInDate       DateTime
  expectedCheckout  DateTime
  actualCheckout    DateTime?
  roomPrice         Decimal       @db.Decimal(10, 2)
  numberOfGuests    Int           @default(1)
  specialRequests   String?
  groupBookingId    String?       // nullable — solo bookings have no group
  groupBooking      GroupBooking? @relation(fields: [groupBookingId], references: [id])
  createdById       String
  createdBy         User          @relation(fields: [createdById], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  invoice       Invoice?
  transfers     RoomTransfer[]
  payments      Payment[]
  nightAuditCharges NightAuditCharge[]
  companyId         String?
  company           Company?      @relation(fields: [companyId], references: [id])
  billingRule       BillingRule   @default(GUEST)

  @@index([status])
  @@index([groupBookingId])
  @@index([roomId])
  @@index([guestId])
  @@index([companyId])
  @@index([checkInDate])
  @@index([expectedCheckout])
  @@index([actualCheckout])
  @@index([createdAt])
  @@map("bookings")
}

// ─── GROUP BOOKINGS ─────────────────────────────────

model GroupBooking {
  id            String             @id @default(uuid())
  groupNumber   String             @unique
  leadGuestId   String
  leadGuest     Guest              @relation(fields: [leadGuestId], references: [id])
  status        GroupBookingStatus @default(ACTIVE)
  notes         String?
  createdById   String
  createdBy     User               @relation(fields: [createdById], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  bookings Booking[]

  @@index([leadGuestId])
  @@index([createdAt])
  @@map("group_bookings")
}

// ─── ROOM TRANSFERS ─────────────────────────────────────

model RoomTransfer {
  id           String   @id @default(uuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id])
  fromRoomId   String
  fromRoom     Room     @relation("TransferFromRoom", fields: [fromRoomId], references: [id])
  toRoomId     String
  toRoom       Room     @relation("TransferToRoom", fields: [toRoomId], references: [id])
  reason       String?
  newRoomPrice Decimal? @db.Decimal(10, 2)
  transferredAt DateTime @default(now())

  @@map("room_transfers")
}

// ─── MENU CATEGORIES ───────────────────────────────────

model MenuCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MenuItem[]

  @@map("menu_categories")
}

// ─── MENU ITEMS ─────────────────────────────────────────

model MenuItem {
  id          String       @id @default(uuid())
  name        String
  price       Decimal      @db.Decimal(10, 2)
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  description String?
  isVeg       Boolean      @default(true)
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  orderItems OrderItem[]

  @@map("menu_items")
}

// ─── ORDERS ─────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  type        OrderType
  status      OrderStatus @default(ACTIVE)
  roomId      String?
  room        Room?       @relation(fields: [roomId], references: [id])
  customerName String?
  subtotal    Decimal     @db.Decimal(10, 2) @default(0)
  tax         Decimal     @db.Decimal(10, 2) @default(0)
  total       Decimal     @db.Decimal(10, 2) @default(0)
  notes       String?
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items    OrderItem[]
  payments Payment[]

  @@index([type, status])
  @@index([createdAt])
  @@index([roomId])
  @@map("orders")
}

// ─── ORDER ITEMS ────────────────────────────────────────

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  quantity     Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  totalPrice   Decimal  @db.Decimal(10, 2)
  isCancelled  Boolean  @default(false)
  cancelReason String?
  cancelledAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

// ─── INVOICES ───────────────────────────────────────────

model Invoice {
  id             String   @id @default(uuid())
  invoiceNumber  String   @unique
  bookingId      String   @unique
  booking        Booking  @relation(fields: [bookingId], references: [id])
  roomCharges    Decimal  @db.Decimal(10, 2) @default(0)
  foodCharges    Decimal  @db.Decimal(10, 2) @default(0)
  extraCharges   Decimal  @db.Decimal(10, 2) @default(0)
  discountAmount Decimal  @db.Decimal(10, 2) @default(0)
  subtotal       Decimal  @db.Decimal(10, 2) @default(0)
  cgst           Decimal  @db.Decimal(10, 2) @default(0)
  sgst           Decimal  @db.Decimal(10, 2) @default(0)
  totalTax       Decimal  @db.Decimal(10, 2) @default(0)
  grandTotal     Decimal  @db.Decimal(10, 2) @default(0)
  amountPaid     Decimal  @db.Decimal(10, 2) @default(0)
  pendingAmount  Decimal  @db.Decimal(10, 2) @default(0)
  isFinalized    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  companyId      String?
  company        Company?   @relation(fields: [companyId], references: [id])
  companyAmount  Decimal    @db.Decimal(10, 2) @default(0.00)
  guestAmount    Decimal    @db.Decimal(10, 2) @default(0.00)
  isBtc          Boolean    @default(false)

  adjustments InvoiceAdjustment[]

  @@index([companyId])
  @@index([createdAt])
  @@map("invoices")
}

// ─── INVOICE ADJUSTMENTS ────────────────────────────────

model InvoiceAdjustment {
  id          String         @id @default(uuid())
  invoiceId   String
  invoice     Invoice        @relation(fields: [invoiceId], references: [id])
  type        AdjustmentType
  amount      Decimal        @db.Decimal(10, 2)
  reason      String
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([invoiceId])
  @@map("invoice_adjustments")
}

// ─── PAYMENTS ───────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid())
  transactionId String        @unique @default(uuid())
  bookingId     String?
  booking       Booking?      @relation(fields: [bookingId], references: [id])
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  type          PaymentType
  reference     String?
  notes         String?
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())

  @@index([bookingId])
  @@map("payments")
}

// ─── TAX CONFIG ─────────────────────────────────────────

model TaxConfig {
  id       String  @id @default(uuid())
  name     String  @unique
  rate     Decimal @db.Decimal(5, 2)
  isActive Boolean @default(true)

  @@map("tax_config")
}

// ─── EXPENSES ───────────────────────────────────────

model Expense {
  id          String          @id @default(uuid())
  title       String
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  paidDate    DateTime
  method      PaymentMethod
  notes       String?
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([paidDate])
  @@index([category])
  @@map("expenses")
}

// ─── AUDIT LOGS ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entity     String
  entityId   String
  details    String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── NIGHT AUDIT ────────────────────────────────────────

model NightAudit {
  id             String           @id @default(uuid())
  businessDate   DateTime         // The hotel business date being closed
  status         NightAuditStatus @default(IN_PROGRESS)

  // Immutable revenue snapshot
  roomRevenue    Decimal  @db.Decimal(10, 2) @default(0)
  foodRevenue    Decimal  @db.Decimal(10, 2) @default(0)
  totalRevenue   Decimal  @db.Decimal(10, 2) @default(0)

  // Payment method breakdown
  cashCollected  Decimal  @db.Decimal(10, 2) @default(0)
  cardCollected  Decimal  @db.Decimal(10, 2) @default(0)
  upiCollected   Decimal  @db.Decimal(10, 2) @default(0)

  // Operational counts
  roomsOccupied  Int      @default(0)
  totalRooms     Int      @default(0)
  newCheckins    Int      @default(0)
  checkoutsToday Int      @default(0)
  noShowsMarked  Int      @default(0)

  // Who ran it
  runById        String
  runBy          User     @relation(fields: [runById], references: [id])
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  notes          String?

  charges        NightAuditCharge[]
  orders         NightAuditOrder[]

  @@index([businessDate])
  @@map("night_audits")
}

// ─── NIGHT AUDIT ORDERS (Immutable Ledger) ──────────────

model NightAuditOrder {
  id            String     @id @default(uuid())
  nightAuditId  String
  nightAudit    NightAudit @relation(fields: [nightAuditId], references: [id], onDelete: Cascade)
  orderId       String
  orderNumber   String
  orderType     OrderType  // ROOM, WALK_IN, TAKEAWAY
  totalAmount   Decimal    @db.Decimal(10, 2)
  billingStatus String     // "PAID_DIRECT" or "CHARGED_TO_ROOM"
  roomNumber    String?
  guestName     String?
  createdAt     DateTime   @default(now())

  @@index([nightAuditId])
  @@map("night_audit_orders")
}

// ─── NIGHT AUDIT CHARGES (Immutable Ledger) ─────────────

model NightAuditCharge {
  id           String     @id @default(uuid())
  nightAuditId String
  nightAudit   NightAudit @relation(fields: [nightAuditId], references: [id])
  bookingId    String
  booking      Booking    @relation(fields: [bookingId], references: [id])
  roomId       String
  room         Room       @relation(fields: [roomId], references: [id])

  businessDate DateTime
  roomRate     Decimal    @db.Decimal(10, 2)
  cgst         Decimal    @db.Decimal(10, 2)
  sgst         Decimal    @db.Decimal(10, 2)
  totalCharge  Decimal    @db.Decimal(10, 2)

  createdAt    DateTime   @default(now())

  @@index([bookingId])
  @@index([nightAuditId])
  @@map("night_audit_charges")
}

// ─── SYSTEM CONFIG (Key-Value Store) ────────────────────

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// ─── COMPANIES (Corporate Accounts) ──────────────────────
model Company {
  id                 String   @id @default(uuid())
  name               String   @unique
  gstin              String?  // Company GST Number
  address            String?
  state              String   @default("Tamil Nadu")
  creditLimit        Decimal  @db.Decimal(10, 2) @default(100000.00)
  outstandingBalance Decimal  @db.Decimal(10, 2) @default(0.00)
  email              String?
  phone              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  bookings  Booking[]
  invoices  Invoice[]
  payments  CompanyPayment[]

  @@map("companies")
}

// ─── COMPANY BULK PAYMENTS (Corporate Reconciliation) ────
model CompanyPayment {
  id            String        @id @default(uuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @default(CASH)
  referenceNo   String?       // NEFT/RTGS transaction reference
  paymentDate   DateTime      @default(now())
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())

  @@index([companyId])
  @@map("company_payments")
}

// ─── BANQUET HALLS ────────────────────────────────────────

model BanquetHall {
  id           String   @id @default(uuid())
  name         String   @unique
  maxCapacity  Int
  baseRental   Decimal  @db.Decimal(10, 2)
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings BanquetBooking[]

  @@map("banquet_halls")
}

// ─── BANQUET BOOKINGS ─────────────────────────────────────

model BanquetBooking {
  id            String         @id @default(uuid())
  bookingNumber String         @unique // BQ2026060001
  guestId       String
  guest         Guest          @relation(fields: [guestId], references: [id])
  hallId        String
  hall          BanquetHall    @relation(fields: [hallId], references: [id])
  createdById   String
  createdBy     User           @relation("BanquetBookingCreator", fields: [createdById], references: [id])

  eventDate     DateTime       // Date of the event
  slot          BanquetSlot
  startTime     DateTime?      // Only populated when slot = CUSTOM
  endTime       DateTime?      // Only populated when slot = CUSTOM
  status        BanquetStatus  @default(PROVISIONAL)

  eventType     String         // "Wedding", "Birthday", "Seminar", etc.
  estimatedPax  Int            // Strictly validated ≤ hall.maxCapacity

  // Pricing breakdown stored at booking time for immutability
  hallRentalPrice  Decimal @db.Decimal(10, 2)
  perHeadFoodPrice Decimal @db.Decimal(10, 2) @default(0)
  extraCharges     Decimal @db.Decimal(10, 2) @default(0)

  // Computed totals (pre-tax)
  subtotal      Decimal @db.Decimal(10, 2)
  cgst          Decimal @db.Decimal(10, 2) @default(0)
  sgst          Decimal @db.Decimal(10, 2) @default(0)
  totalAmount   Decimal @db.Decimal(10, 2)

  // Running ledger balances
  advancePaid   Decimal @db.Decimal(10, 2) @default(0)
  pendingAmount Decimal @db.Decimal(10, 2)

  notes         String?
  foodPreference FoodPreference @default(NONE)
  cancelReason  String?
  cancelledAt   DateTime?

  payments BanquetPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventDate])
  @@index([status])
  @@index([hallId, eventDate])
  @@index([createdAt])
  @@map("banquet_bookings")
}

// ─── BANQUET PAYMENTS ─────────────────────────────────────

model BanquetPayment {
  id          String             @id @default(uuid())
  bookingId   String
  booking     BanquetBooking     @relation(fields: [bookingId], references: [id])
  amount      Decimal            @db.Decimal(10, 2)
  method      PaymentMethod
  type        BanquetPaymentType
  reference   String?
  notes       String?
  createdById String
  createdBy   User               @relation("BanquetPaymentCreator", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())

  @@index([bookingId])
  @@map("banquet_payments")
}

enum FoodPreference {
  VEG
  NON_VEG
  BOTH
  NONE
}
